VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── MCP server (Firebase Admin + agent hook) ──
# Used by mcp-server/ (npm scripts + agent-hook). The MCP server itself, when
# launched from your MCP client config, gets these from that config's env block.
FIREBASE_PROJECT_ID=vibe-board-3b2cf

# Service-account credentials. Use an ABSOLUTE path so it resolves the same from
# any working directory (the npm scripts run from mcp-server/, the hook from the
# repo root). Or paste the JSON via FIREBASE_SERVICE_ACCOUNT instead.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vibe-board/mcp-server/service-account.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# The API key the MCP server acts as (created via `npm run create-key`).
FLOWMANCER_API_KEY=fmk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
